# Copy to `.env` to customize the MarkItDown web app (docker compose reads it).

# Where the document library is stored inside the container. Mapped to the
# `markitdown-data` volume by docker-compose; usually leave as-is.
MARKITDOWN_DATA_DIR=/data

# Max size per uploaded file, in megabytes. 0 = unlimited (the default).
# Uploads are streamed to disk, so "unlimited" is bounded by disk space, not RAM.
MARKITDOWN_MAX_UPLOAD_MB=0

# --- Optional: LLM image descriptions / captions -------------------------
# Uncomment and fill in to let MarkItDown describe images inside documents.
# MARKITDOWN_LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...
# For an OpenAI-compatible endpoint (Azure OpenAI, local, etc.):
# OPENAI_BASE_URL=https://your-endpoint/v1
